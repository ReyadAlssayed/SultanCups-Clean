@page "/Sales-payments"
@layout Layout.MainLayout

<div class="sp-page">

    <div class="sp-topbar">
        <button class="sp-btn sp-btn-add" @onclick="OpenAddDialog">إضافة تحصيل</button>
        <h2 class="sp-title">تحصيل المبيعات</h2>
        <div></div>
    </div>

    <div class="sp-card">
        <div class="sp-table-wrap">
            <table class="sp-table">
                <thead>
                    <tr>
                        <th>رقم الفاتورة</th>
                        <th>الخزنة</th>
                        <th>المبلغ المدفوع</th>
                        <th>طريقة الدفع</th>
                        <th>تاريخ الدفع</th>
                        <th>ملاحظات</th>
                        <th>الإجراءات</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var p in PaymentList)
                    {
                        <tr>
                            <td class="sp-code">@p.orderNumber</td>
                            <td>@p.cashBox</td>
                            <td class="sp-money sp-amount">@Fmt(p.amountPaid)</td>
                            <td>@p.method</td>
                            <td class="sp-muted">@p.payDate.ToString("yyyy-MM-dd")</td>
                            <td class="sp-muted">@p.notes</td>

                            <td class="sp-actions-cell">
                                <button class="sp-small sp-edit" @onclick="() => OpenEditDialog(p)">تعديل</button>
                                <button class="sp-small sp-del" @onclick="() => OpenDeleteDialog(p)">حذف</button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (ShowAddDialog || ShowEditDialog)
{
    <div class="sp-dialog-overlay">
        <div class="sp-dialog-box">
            <div class="sp-dialog-top-image">
                <img src="images/Background.jpg" />
            </div>
            <div class="sp-dialog-body">
                <h3>@(ShowAddDialog ? "إضافة عملية تحصيل" : "تعديل عملية التحصيل")</h3>
                
                <div class="sp-fields-grid">
                    <div class="sp-field">
                        <label class="sp-label">رقم الفاتورة</label>
                        <input class="sp-input-dialog" @bind="PayForm.orderNumber" />
                    </div>
                    <div class="sp-field">
                        <label class="sp-label">الخزنة</label>
                        <input class="sp-input-dialog" @bind="PayForm.cashBox" />
                    </div>
                    <div class="sp-field">
                        <label class="sp-label">المبلغ المدفوع</label>
                        <input class="sp-input-dialog" type="number" step="0.01" @bind="PayForm.amountPaid" />
                    </div>
                    <div class="sp-field">
                        <label class="sp-label">طريقة الدفع</label>
                        <input class="sp-input-dialog" @bind="PayForm.method" />
                    </div>
                    <div class="sp-field">
                        <label class="sp-label">تاريخ الدفع</label>
                        <input class="sp-input-dialog" type="date" @bind="PayForm.payDate" />
                    </div>
                    <div class="sp-field full-width">
                        <label class="sp-label">ملاحظات</label>
                        <textarea class="sp-input-dialog" @bind="PayForm.notes"></textarea>
                    </div>
                </div>

                <div class="sp-dialog-actions">
                    <button type="button" class="sp-save">حفظ</button>
                    <button type="button" class="sp-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowDeleteDialog)
{
    <div class="sp-dialog-overlay">
        <div class="sp-dialog-box sp-delete-dialog-box">
            <div class="sp-dialog-top-image sp-delete-top-image">
                <img src="images/Background.jpg" />
            </div>
            <div class="sp-dialog-body sp-delete-dialog-body">
                <div class="sp-delete-icon-wrap"><div class="sp-delete-icon">!</div></div>
                <h3 class="sp-delete-title">تأكيد الحذف</h3>
                <p class="sp-delete-text">هل تريد حذف عملية تحصيل الفاتورة "@PayForm.orderNumber"؟</p>
                <div class="sp-dialog-actions">
                    <button type="button" class="sp-delete-confirm">حذف</button>
                    <button type="button" class="sp-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    List<PaymentRow> PaymentList = new()
    {
        new() { orderNumber = "INV-1001", cashBox = "الخزنة الرئيسية", amountPaid = 200m, method = "كاش", payDate = new DateTime(2026,3,5), notes = "دفعة أولى" },
        new() { orderNumber = "INV-1002", cashBox = "خزنة الفرع", amountPaid = 150m, method = "بطاقة", payDate = new DateTime(2026,3,4), notes = "" }
    };

    bool ShowAddDialog, ShowEditDialog, ShowDeleteDialog;
    PaymentRow PayForm = new();

    string Fmt(decimal v) => $"{v:0.00} د.ل";

    void OpenAddDialog() { PayForm = new PaymentRow { payDate = DateTime.Now }; ShowAddDialog = true; }
    void OpenEditDialog(PaymentRow p)
    {
        PayForm = new PaymentRow
        {
            orderNumber = p.orderNumber,
            cashBox = p.cashBox,
            amountPaid = p.amountPaid,
            method = p.method,
            payDate = p.payDate,
            notes = p.notes
        };
        ShowEditDialog = true;
    }
    void OpenDeleteDialog(PaymentRow p) { PayForm = p; ShowDeleteDialog = true; }
    void CloseDialogs() => ShowAddDialog = ShowEditDialog = ShowDeleteDialog = false;

    public class PaymentRow
    {
        public string orderNumber { get; set; } = "";
        public string cashBox { get; set; } = "";
        public decimal amountPaid { get; set; }
        public string method { get; set; } = "";
        public DateTime payDate { get; set; }
        public string notes { get; set; } = "";
    }
}