                    @CashBoxes.FirstOrDefault(x => x.cash_box_id == SalaryForm.cash_box_id)?.name
                </p>

                <div class="pro-field">
                    <label class="pro-label">المبلغ</label>

                    <input class="pro-input"
                           type="number"
