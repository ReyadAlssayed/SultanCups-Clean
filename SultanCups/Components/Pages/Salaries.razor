@page "/Salaries"
@using SultanCups.Models
@layout Layout.MainLayout
@inject NavigationManager Nav
@inject SultanCups.Services.FinanceService FinanceService
@inject SultanCups.Services.ToastService ToastService
@inject SultanCups.Services.UserSession Session

@using ClosedXML.Excel
@inject IJSRuntime JS


<div class="pro-page">

    
    <div class="pro-topbar">

        <button class="pro-btn-add" @onclick="OpenAddDialog">
            إضافة راتب
        </button>

        <h2 class="pro-title">الرواتب</h2>

        <button class="pro-btn-excel"
                @onclick="ExportToExcel"
                disabled="@IsExporting">
            أرشفة Excel
        </button>

        <div></div>

    </div>

    <div class="pro-card">
        <div class="pro-table-wrap">
            <table class="pro-table">
                <thead>
                    <tr>
                        <th>الموظف</th>
                        <th>النوع</th>
                        <th>المستحق</th>
                        <th>المدفوع</th>
                        <th>المتبقي</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>الخزنة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Salarie == null)
                    {
                        <tr>
                            <td colspan="9" class="pro-empty">
                                جاري التحميل...
                            </td>
                        </tr>
                    }
                    else if (Salarie.Count == 0)
                    {
                        <tr>
                            <td colspan="9" class="st-empty-text">
                                <div class="empty-state">

                                    <img src="images/Empty.jpg" class="empty-img" />

                                    <span>لا توجد بيانات</span>

                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var s in Salarie)
                        {
                            <tr>
                                <td>@s.Employee.full_name</td>

                                <td>@s.salary_type</td>

                                <td class="pro-money">
                                    @s.amount.ToString("0.00") د.ل
                                </td>

                                <td class="pro-money">
                                    @s.paid_amount.ToString("0.00") د.ل
                                </td>

                                <td class="pro-money">
                                    @s.Remaining.ToString("0.00") د.ل
                                </td>

                                <td>
                                    <span class="emp-badge @(s.status == "خالص" ? "emp-on" : "emp-off")">
                                        @s.status
                                    </span>
                                </td>

                                <td class="mg-date-cell">
                                    <span class="mg-date">
                                        @s.salary_date.ToLocalTime().ToString("yyyy-MM-dd")
                                    </span>
                                </td>
                                <td>@s.CashBox.name</td>

                                <td class="emp-actions">

                                    <button class="emp-edit"
                                            @onclick="() => OpenAddPaymentDialog(s)">
                                         إضافة دفعة
                                    </button>

                                    <button class="emp-edit"
                                            @onclick="() => OpenReverseDialog(s)">
                                         إلغاء دفعة
                                    </button>

                                    <button class="emp-edit"
                                            @onclick="() => OpenEditDialog(s)">
                                        تعديل
                                    </button>

                                    <button class="emp-delete"
                                            @onclick="() => OpenDeleteDialog(s)">
                                        حذف
                                    </button>













                                </td>
                            </tr>
                        }
                    }

                </tbody>
            </table>
        </div>
    </div>

</div>

<!-- إضافة راتب -->
@if (ShowAddDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

            <div class="pro-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="pro-dialog-body">

                <div class="money-head">
                    <h3>إضافة راتب</h3>
                    <img src="images/Money.jpg" />
                </div>

                <div class="pro-fields-grid">

                    <div class="pro-field">
                        <label class="pro-label">نوع الراتب</label>

                        <select class="pro-input"
                                value="@SalaryForm.salary_type"
                                @onchange="@(e => SalaryForm.salary_type = e.Value?.ToString())">

                            <option value="راتب أساسي">راتب أساسي</option>
                            <option value="طلعة">طلعة</option>
                        </select>
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الموظف</label>

                        <select @bind="SelectedEmployeeId" class="pro-input">
                            <option value="0">اختر الموظف</option>
                            @foreach (var e in Employees)
                            {
                                <option value="@e.employee_id">@e.full_name</option>
                            }
                        </select>

                        @if (!string.IsNullOrWhiteSpace(EmployeeError))
                        {
                            <div class="pro-error-text">@EmployeeError</div>
                        }
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">المبلغ المستحق</label>
                        <input class="pro-input"
                               @bind-value="SalaryForm.amount"
                               @bind-value:event="oninput" />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">المدفوع</label>
                        <input class="pro-input"
                               @bind-value="SalaryForm.paid_amount"
                               @bind-value:event="oninput" />

                        @if (!string.IsNullOrWhiteSpace(PaidError))
                        {
                            <div class="pro-error-text">@PaidError</div>
                        }
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">المتبقي</label>
                        <input class="pro-input"
                               value="@GetRemaining()"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الحالة</label>
                        <input class="pro-input"
                               value="@GetStatus()"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الخزنة</label>
                        <select @bind="selectedCashBoxId" class="pro-input">
                            <option value="0">اختر الخزنة</option>
                            @foreach (var c in CashBoxes)
                            {
                                <option value="@c.cash_box_id">@c.name</option>
                            }
                        </select>

                        @if (!string.IsNullOrWhiteSpace(CashBoxError))
                        {
                            <div class="pro-error-text">@CashBoxError</div>
                        }
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">التاريخ</label>
                        <input type="date"
                               class="pro-input"
                               @bind="SalaryForm.salary_date" />
                    </div>

                    <div class="pro-field" style="grid-column: span 2;">
                        <label class="pro-label">ملاحظة</label>
                        <input class="pro-input"
                               @bind="SalaryForm.notes" />
                    </div>

                </div>

                <div class="pro-dialog-actions">
                    <button class="pro-save"
                            @onclick="SaveSalary">
                        حفظ
                    </button>

                    <button class="pro-cancel"
                            @onclick="CloseDialogs">
                        إلغاء
                    </button>
                </div>

            </div>
        </div>
    </div>
}

@if (ShowEditDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

            <div class="pro-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="pro-dialog-body">

                <h3>تعديل الراتب</h3>

                <div class="pro-fields-grid">

                    <div class="pro-field">
                        <label class="pro-label">نوع الراتب</label>

                        <select class="pro-input"
                                value="@SalaryForm.salary_type"
                                @onchange="@(e => SalaryForm.salary_type = e.Value?.ToString() ?? "")">

                            <option value="راتب أساسي">راتب أساسي</option>
                            <option value="طلعة">طلعة</option>
                        </select>
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الموظف</label>
                        <select @bind="SelectedEmployeeId" class="pro-input">
                            @foreach (var e in Employees)
                            {
                                <option value="@e.employee_id">@e.full_name</option>
                            }
                        </select>
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">المبلغ المستحق</label>
                        <input class="pro-input"
                               @bind="SalaryForm.amount" />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الخزنة</label>

                        <select class="pro-input"
                                value="@selectedCashBoxId"
                                @onchange="@(e => selectedCashBoxId = int.Parse(e.Value!.ToString()!))">

                            @foreach (var c in CashBoxes)
                            {
                                <option value="@c.cash_box_id">@c.name</option>
                            }
                        </select>
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الحالة</label>
                        <input class="pro-input"
                               value="@SalaryForm.status"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">التاريخ</label>
                        <input type="date"
                               class="pro-input"
                               @bind="SalaryForm.salary_date" />
                    </div>

                    <div class="pro-field" style="grid-column: span 2;">
                        <label class="pro-label">ملاحظة</label>
                        <input class="pro-input"
                               @bind="SalaryForm.notes" />
                    </div>

                </div>

                <div class="pro-dialog-actions">
                    <button class="pro-save"
                            @onclick="UpdateSalaryAction">
                        حفظ
                    </button>

                    <button class="pro-cancel"
                            @onclick="CloseDialogs">
                        إلغاء
                    </button>
                </div>

            </div>
        </div>
    </div>
}
<!-- إضافة دفعة -->
@if (ShowAddPaymentDialog)
{
    <div class="pro-dialog-overlay">

        <div class="pro-dialog-box">

            <div class="pro-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="pro-dialog-body">

               
                <div class="money-head">
                    
                    <h3>إضافة دفعة</h3>
                    <img src="images/Money.jpg" />
                </div>

                <p class="money-note">
                    سيتم خصم المبلغ من خزنة:
                    @CashBoxes.FirstOrDefault(x => x.cash_box_id == SalaryForm.cash_box_id)?.name
                </p>

                <div class="pro-field">
                    <label class="pro-label">المبلغ</label>

                    <input class="pro-input"
                           type="number"
                           step="0.01"
                           @bind-value="PaymentAmount"
                           @bind-value:event="oninput" />

                    @if (!string.IsNullOrWhiteSpace(PaymentError))
                    {
                        <div class="pro-error-text">@PaymentError</div>
                    }
                </div>

                <div class="pro-dialog-actions">
                    <button class="pro-save" @onclick="AddPaymentAction">حفظ</button>
                    <button class="pro-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>

            </div>
        </div>
    </div>
}

<!-- إلغاء دفعة -->
@if (ShowReverseDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

                <div class="pro-dialog-top-image">
                    <img src="images/Background.png" />
                </div>

            <div class="pro-dialog-body">

                <div class="money-head">
                    
