                           @bind-value="PaymentAmount"
                           @bind-value:event="oninput" />

                    @if (!string.IsNullOrWhiteSpace(PaymentError))
                    {
                        <div class="pro-error-text">@PaymentError</div>
                    }
                </div>

                <div class="pro-dialog-actions">
