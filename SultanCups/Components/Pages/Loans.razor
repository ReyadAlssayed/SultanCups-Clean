                    <div class="pro-field">
                        <label class="pro-label">المسدد</label>

                        <input class="pro-input"
                               value="@LoanForm.repaid_amount"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الحالة</label>

                        <input class="pro-input"
                               value="@LoanForm.status"
                               disabled />
