@if (ShowDiffDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

            <div class="pro-dialog-body">

                <div class="money-head">
                    <h3>تأكيد التعديل المالي</h3>
                    <img src="images/Money.jpg" />
                </div>

                <div class="diff-row">
                    <span>السلفة السابقة</span>
                    <b>@OldLoanAmount د.ل</b>
                </div>

                <div class="diff-row">
                    <span>السلفة الجديدة</span>
                    <b>@NewLoanAmount د.ل</b>
                </div>

                <div class="diff-row">
                    <span>الفرق</span>
                    <b>@Math.Abs(LoanDiff) د.ل</b>
                </div>

                <p class="diff-note">
                    @(LoanDiff > 0
                    ? "سيتم إخراج فرق المبلغ من الخزنة"
                    : "سيتم إدخال فرق المبلغ إلى الخزنة")
                </p>

                <div class="pro-dialog-actions">
                    <button class="pro-save" @onclick="ConfirmLoanEdit">
                        متابعة
                    </button>

                    <button class="pro-cancel" @onclick="CloseDialogs">
                        إلغاء
                    </button>
                </div>

            </div>
        </div>
    </div>
}


@if (ShowFinalDeleteDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

            <div class="pro-dialog-body">

                <div class="money-head delete-head">
                    <h3>تأكيد نهائي</h3>
                    <img src="images/Money.jpg" />
                </div>

                <p style="white-space:pre-line;text-align:center;line-height:2">
                    @FinalDeleteMessage
                </p>

                <div class="pro-dialog-actions">
                    <button class="pro-delete-confirm"
                            @onclick="ConfirmFinalDelete">
                        نعم احذف
                    </button>

                    <button class="pro-cancel"
                            @onclick="CloseDialogs">
                        إلغاء
                    </button>
                </div>

            </div>
        </div>
    </div>
}


@code {

    List<EmployeeLoan>? Loan;
    List<Employee> Employees = new();
    List<CashBox> CashBoxes = new();

    EmployeeLoan LoanForm = new();

    int SelectedEmployeeId;
    int selectedCashBoxId;

    bool ShowAddDialog;
    bool ShowEditDialog;
    bool ShowPaymentDialog;
    bool ShowReverseDialog;
    bool ShowDeleteDialog;

    bool ShowFinalDeleteDialog;
    string FinalDeleteMessage = "";
    
    string EmployeeError = "";
    string CashError = "";
    string AmountError = "";

    bool ShowDiffDialog;

    decimal OldLoanAmount;
    decimal NewLoanAmount;
    decimal LoanDiff;

    int DeleteLoanId;

    decimal PaymentAmount;



    protected override async Task OnInitializedAsync()
    {
        if (!Session.IsLoggedIn)
        {
            Nav.NavigateTo("/");
            return;
        }

        Loan = await FinanceService.GetLoans();
        Employees = await FinanceService.GetActiveEmployees();
        CashBoxes = await FinanceService.GetActiveCashBoxes();
    }

    void OpenAddDialog()
    {
        LoanForm = new EmployeeLoan
        {
            loan_date = DateTime.UtcNow
        };

        SelectedEmployeeId = 0;
        selectedCashBoxId = 0;
        EmployeeError = "";
        CashError = "";
        AmountError = "";

        ShowAddDialog = true;
    }

    void OpenEditDialog(EmployeeLoan row)
    {
        LoanForm = new EmployeeLoan
        {
            loan_id = row.loan_id,
            employee_id = row.employee_id,
            cash_box_id = row.cash_box_id,
            loan_amount = row.loan_amount,
            repaid_amount = row.repaid_amount,
            status = row.status,
            loan_date = row.loan_date,
            notes = row.notes
        };

        SelectedEmployeeId = row.employee_id;
        selectedCashBoxId = row.cash_box_id;

        OldLoanAmount = row.loan_amount;

        ShowEditDialog = true;
    }

    async Task ConfirmLoanEdit()
    {
        LoanForm.employee_id = SelectedEmployeeId;
        LoanForm.cash_box_id = selectedCashBoxId;

        await FinanceService.UpdateLoan(LoanForm, Session.AdminId);

        Loan = await FinanceService.GetLoans();

        CloseDialogs();

        ToastService.ShowToast("تم تعديل السلفة", "success");
    }

    void OpenPaymentDialog(EmployeeLoan row)
    {
        LoanForm = row;
        PaymentAmount = 0;
        ShowPaymentDialog = true;
    }

    void OpenReverseDialog(EmployeeLoan row)
    {
        LoanForm = row;
        PaymentAmount = 0;
        ShowReverseDialog = true;
    }

    void OpenDeleteDialog(EmployeeLoan row)
    {
        LoanForm = row;
        DeleteLoanId = row.loan_id;
        ShowDeleteDialog = true;
    }

    async Task SaveLoan()
    {
        EmployeeError = "";
        CashError = "";
        AmountError = "";

        if (SelectedEmployeeId <= 0)
        {
            EmployeeError = "اختر الموظف";
            return;
        }

        if (selectedCashBoxId <= 0)
        {
            CashError = "اختر الخزنة";
            return;
        }

        if (LoanForm.loan_amount <= 0)
        {
            AmountError = "القيمة يجب أن تكون أكبر من 0";
            return;
        }

        try
        {
            LoanForm.employee_id = SelectedEmployeeId;
            LoanForm.cash_box_id = selectedCashBoxId;

            // 🔥 تنبيه إذا لديه راتب غير خالص
            var salaryRemaining =
                await FinanceService.GetEmployeeSalaryRemaining(SelectedEmployeeId);

            if (salaryRemaining > 0)
            {
                var ok = await JS.InvokeAsync<bool>(
                    "confirm",
                    $"تنبيه:\n\nهذا الموظف لديه راتب متبقي بقيمة {salaryRemaining:0.00} د.ل.\n\nهل تريد الاستمرار؟");

                if (!ok)
                    return;
            }

            await FinanceService.AddLoan(LoanForm, Session.AdminId);

            Loan = await FinanceService.GetLoans();

            CloseDialogs();

            ToastService.ShowToast(
                "تمت إضافة السلفة وخرج المبلغ فعليًا من الخزنة",
                "success"
            );
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(
                ex.InnerException?.Message ?? ex.Message,
                "error"
            );
        }
    }

    async Task UpdateLoanAction()
    {
        try
        {
            if (LoanForm.loan_amount <= 0)
            {
                ToastService.ShowToast("القيمة يجب أن تكون أكبر من 0", "error");
                return;
            }

            NewLoanAmount = LoanForm.loan_amount;
            LoanDiff = NewLoanAmount - OldLoanAmount;

            if (LoanDiff == 0)
            {
                LoanForm.employee_id = SelectedEmployeeId;
                LoanForm.cash_box_id = selectedCashBoxId;

                await FinanceService.UpdateLoan(LoanForm, Session.AdminId);

                Loan = await FinanceService.GetLoans();

                CloseDialogs();

                ToastService.ShowToast("تم تعديل السلفة", "success");
                return;
            }

            ShowEditDialog = false;
            ShowDiffDialog = true;
        }
        catch (Exception ex)
        {
            ToastService.ShowToast(ex.InnerException?.Message ?? ex.Message, "error");
        }
    }

    async Task AddPaymentAction()
    {
        if (LoanForm.status == "خالص")
        {
            ToastService.ShowToast("هذه السلفة خالصة فعليًا", "error");
            return;
        }

        if (PaymentAmount <= 0)
        {
            ToastService.ShowToast("القيمة يجب أن تكون أكبر من 0", "error");
            return;
        }

        var remaining = LoanForm.loan_amount - LoanForm.repaid_amount;

        if (PaymentAmount > remaining)
        {
            ToastService.ShowToast("المبلغ أكبر من المتبقي", "error");
            return;
        }

        var ok = await FinanceService.AddLoanPayment(
            LoanForm.loan_id,
            PaymentAmount,
            Session.AdminId);

        if (ok)
        {
            Loan = await FinanceService.GetLoans();
            CloseDialogs();

            ToastService.ShowToast("تم سداد السلفة بنجاح", "success");
        }
    }
  
    async Task ReversePaymentAction()
    {
        if (LoanForm.repaid_amount <= 0)
        {
            ToastService.ShowToast("هو لم يدفع شيئًا أساسًا", "error");
            return;
        }

        if (PaymentAmount <= 0)
        {
            ToastService.ShowToast("القيمة يجب أن تكون أكبر من 0", "error");
            return;
        }

        if (PaymentAmount > LoanForm.repaid_amount)
        {
            ToastService.ShowToast("المبلغ أكبر من المدفوع", "error");
            return;
        }

        var ok = await FinanceService.ReverseLoanPayment(
            LoanForm.loan_id,
            PaymentAmount,
            Session.AdminId);

        if (ok)
        {
            Loan = await FinanceService.GetLoans();
            CloseDialogs();

            ToastService.ShowToast("تم إلغاء السداد", "success");
        }
    }

    Task DeleteLoanAction()
    {
        var paid = LoanForm.repaid_amount;
        var remaining = LoanForm.loan_amount - LoanForm.repaid_amount;
        var total = LoanForm.loan_amount;

        if (paid == 0)
        {
            FinalDeleteMessage =
            $"لم يتم سداد أي مبلغ من هذه السلفة.\n\n" +
            $"سيتم حذف السلفة بالكامل ورجوع المال إلى الخزنة.";
        }
        else if (remaining == 0)
        {
            FinalDeleteMessage =
            $"تم سداد السلفة بالكامل بقيمة {total:0.00} د.ل.\n\n" +
            $"تأكد أنك أرجعت المبلغ المدفوع للموظف أولاً.";
        }
        else
        {
            FinalDeleteMessage =
            $"تم سداد {paid:0.00} د.ل والمتبقي {remaining:0.00} د.ل.\n\n" +
            $"تأكد أنك أرجعت {paid:0.00} د.ل للموظف، " +
            $"ورجعت كامل مبلغ السلفة إلى الخزنة ليتم حذف السلفة نهائيًا.";
        }

        ShowDeleteDialog = false;
        ShowFinalDeleteDialog = true;

        return Task.CompletedTask;
    }

    async Task ConfirmFinalDelete()
    {
        await FinanceService.DeleteLoan(DeleteLoanId, Session.AdminId);

        Loan = await FinanceService.GetLoans();

        CloseDialogs();

        ToastService.ShowToast("تم حذف السلفة", "success");
    }

    void CloseDialogs()
    {
        ShowAddDialog = false;
        ShowEditDialog = false;
        ShowPaymentDialog = false;
        ShowReverseDialog = false;
        ShowDeleteDialog = false;

        PaymentAmount = 0;

        EmployeeError = "";
        CashError = "";
        AmountError = "";

        SelectedEmployeeId = 0;
        selectedCashBoxId = 0;

        ShowDiffDialog = false;
