@page "/Loans"
@using SultanCups.Models
@layout Layout.MainLayout
@inject NavigationManager Nav
@inject SultanCups.Services.FinanceService FinanceService
@inject SultanCups.Services.ToastService ToastService
@inject SultanCups.Services.UserSession Session
@inject IJSRuntime JS

<div class="pro-page">

    <div class="pro-topbar">

        <button class="pro-btn-add" @onclick="OpenAddDialog">
            إضافة سلفة
        </button>

        <h2 class="pro-title">السلف</h2>

        <div></div>

        <div></div>

    </div>

    <div class="pro-card">
        <div class="pro-table-wrap">

            <table class="pro-table">

                <thead>
                    <tr>
                        <th>الموظف</th>
                        <th>قيمة السلفة</th>
                        <th>المسدد</th>
                        <th>المتبقي</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                        <th>الخزنة</th>
                        <th>إجراءات</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Loan == null)
                    {
                        <tr>
                            <td colspan="8" class="pro-empty">جاري التحميل...</td>
                        </tr>
                    }
                    else if (Loan.Count == 0)
                    {
                        <tr>
                            <td colspan="12" class="st-empty-text">
                                <div class="empty-state">
                                    <img src="images/Empty.jpg" class="empty-img" />
                                    <span>لا توجد بيانات</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var l in Loan)
                        {
                            <tr>

                                <td>@l.Employee.full_name</td>

                                <td class="pro-money">
                                    @l.loan_amount.ToString("0.00") د.ل
                                </td>

                                <td class="pro-money">
                                    @l.repaid_amount.ToString("0.00") د.ل
                                </td>

                                <td class="pro-money">
                                    @l.Remaining.ToString("0.00") د.ل
                                </td>

                                <td>
                                    <span class="emp-badge @(l.status == "خالص" ? "emp-on" : "emp-off")">
                                        @l.status
                                    </span>
                                </td>

                                <td class="mg-date-cell">
                                    <span class="mg-time">
                                        @l.loan_date.ToLocalTime().ToString("HH:mm")
                                    </span>

                                    <span class="mg-date">
                                        @l.loan_date.ToLocalTime().ToString("yyyy-MM-dd")
                                    </span>
                                </td>

                                <td>@l.CashBox.name</td>

                                <td class="emp-actions">

                                    <button class="emp-edit"
                                            @onclick="() => OpenPaymentDialog(l)">
                                        سداد
                                    </button>

                                    <button class="emp-edit"
                                            @onclick="() => OpenReverseDialog(l)">
                                        إلغاء سداد
                                    </button>

                                    <button class="emp-edit"
                                            @onclick="() => OpenEditDialog(l)">
                                        تعديل
                                    </button>

                                    <button class="emp-delete"
                                            @onclick="() => OpenDeleteDialog(l)">
                                        حذف
                                    </button>

                                </td>

                            </tr>
                        }
                    }

                </tbody>

            </table>

        </div>
    </div>

</div>

@if (ShowAddDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

            <div class="pro-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="pro-dialog-body">

                <div class="money-head">
                    <h3>إضافة سلفة</h3>
                    <img src="images/Money.jpg" />
                </div>

                <div class="pro-fields-grid">

                    <div class="pro-field">
                        <label class="pro-label">الموظف</label>

                        <select @bind="SelectedEmployeeId"
                                class="pro-input @(EmployeeError == "" ? "" : "is-invalid")">
                            
                            <option value="0">اختر الموظف</option>

                            @foreach (var e in Employees)
                            {
                                <option value="@e.employee_id">@e.full_name</option>
                            }
                        </select>
                        @if (EmployeeError != "")
                        {
                            <div class="pro-error-text">@EmployeeError</div>
                        }
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الخزنة</label>

                        <select @bind="selectedCashBoxId"
                                class="pro-input @(CashError == "" ? "" : "is-invalid")">
                           
                            <option value="0">اختر الخزنة</option>

                            @foreach (var c in CashBoxes)
                            {
                                <option value="@c.cash_box_id">@c.name</option>
                            }
                        </select>
                        @if (CashError != "")
                        {
                            <div class="pro-error-text">@CashError</div>
                        }
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">قيمة السلفة</label>

                        <input class="pro-input @(AmountError == "" ? "" : "is-invalid")"
                               @bind-value="LoanForm.loan_amount"
                               @bind-value:event="oninput" />
                        @if (AmountError != "")
                        {
                            <div class="pro-error-text">@AmountError</div>
                        }
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">المسدد</label>

                        <input class="pro-input"
                               value="0.00"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">المتبقي</label>

                        <input class="pro-input"
                               value="@LoanForm.loan_amount"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">الحالة</label>

                        <input class="pro-input"
                               value="غير خالص"
                               disabled />
                    </div>

                    <div class="pro-field">
                        <label class="pro-label">التاريخ</label>

                        <input type="date"
                               class="pro-input"
                               @bind="LoanForm.loan_date" />
                    </div>

                    <div class="pro-field" style="grid-column: span 2;">
                        <label class="pro-label">ملاحظة</label>

                        <input class="pro-input"
                               @bind="LoanForm.notes" />
                    </div>

                </div>

                <div class="pro-dialog-actions">
                    <button class="pro-save" @onclick="SaveLoan">حفظ</button>
                    <button class="pro-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>

            </div>
        </div>
    </div>
}

@if (ShowEditDialog)
