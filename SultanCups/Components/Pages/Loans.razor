                <div class="pro-dialog-actions">
                    <button class="pro-save" @onclick="AddPaymentAction">حفظ</button>
                    <button class="pro-cancel" @onclick="CloseDialogs">إلغاء</button>
                </div>

            </div>
        </div>
    </div>
}

