@if (ShowPaymentDialog)
{
    <div class="pro-dialog-overlay">
        <div class="pro-dialog-box">

            <div class="pro-dialog-top-image">
                <img src="images/Background.png" />
            </div>

            <div class="pro-dialog-body">

                <div class="money-head">
                    <h3>سداد سلفة</h3>
                    <img src="images/Money.jpg" />
                </div>

                <div class="diff-row">
                    <span>قيمة السلفة</span>
                    <b>@LoanForm.loan_amount</b>
                </div>

                <div class="diff-row">
                    <span>المتبقي</span>
                    <b>@(LoanForm.loan_amount - LoanForm.repaid_amount)</b>
                </div>

                <p class="diff-note">أدخل المبلغ الذي تم استرداده</p>

                <div class="pro-field">
                    <label class="pro-label">المبلغ</label>

                    <input class="pro-input"
                           @bind-value="PaymentAmount"
                           @bind-value:event="oninput" />
