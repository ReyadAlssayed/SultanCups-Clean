@page "/Debts"
@layout Layout.MainLayout
@using SultanCups.Models
@using SultanCups.Services
@inject FinanceService2 FinanceService

<div class="pro-page">

    ```
    <div class="pro-topbar">
        <div></div>
        <h2 class="pro-title">سجل الديون</h2>
        <div></div>
    </div>

    <!-- 🔍 البحث والفلاتر -->
    <div class="pro-search-bar">

        <input class="mk-search-input"
               placeholder="بحث بالاسم"
               @bind="NameSearch"
               @bind:event="oninput" />

        <select class="pro-filter-select" @bind="PersonFilter">
            <option value="all">الكل</option>
            <option value="customer">زبائن</option>
            <option value="marketer">مسوقين</option>
        </select>

        <select class="pro-filter-select" @bind="StatusFilter">
            <option value="all">كل الحالات</option>
            <option value="full">دين كامل</option>
            <option value="partial">خالص جزئي</option>
        </select>

        <select class="pro-filter-select" @bind="YearFilter">
            <option value="0">كل السنوات</option>
            @foreach (var y in Years)
            {
                <option value="@y">@y</option>
            }
        </select>

        <select class="pro-filter-select" @bind="MonthFilter">
            <option value="0">كل الشهور</option>
            @for (int i = 1; i <= 12; i++)
            {
                <option value="@i">@i</option>
            }
        </select>

        <input type="date"
               class="pro-filter-select"
               @bind="DayFilter" />

    </div>

    <div class="pro-card">

        <div class="pro-table-wrap">

            <table class="pro-table">
                <thead>
                    <tr>
                        <th>رقم الفاتورة</th>
                        <th>الاسم</th>
                        <th>الإجمالي</th>
                        <th>المدفوع</th>
                        <th>المتبقي</th>
                        <th>الحالة</th>
                        <th>التاريخ</th>
                    </tr>
                </thead>

                <tbody>

                    @if (FilteredList == null)
                    {
                        <tr>
                            <td colspan="7">جاري التحميل...</td>
                        </tr>
                    }
                    else if (!FilteredList.Any())
                    {
                        <tr>
                            <td colspan="7" class="st-empty-text">
                                <div class="empty-state">
                                    <img src="images/Empty.jpg" class="empty-img" />
                                    <span>لا توجد ديون</span>
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var d in FilteredList)
                        {
                            <tr>
                                <td class="pro-code">@d.order_id</td>
                                <td>@d.person_name</td>

                                <td>
                                    <span class="pro-total">@Fmt(d.net_total)</span>
                                </td>

                                <td>@Fmt(d.paid_amount)</td>

                                <td>
                                    <span class="pro-total" style="color:#dc2626;">
                                        @Fmt(d.remaining)
                                    </span>
                                </td>

                                <td>
                                    <span class="@(d.status == "دين كامل" ? "st-badge st-badge-danger" : "st-badge st-badge-warning")">
                                        @d.status
                                    </span>
                                </td>

                                <td>@d.order_date.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    }

                </tbody>
            </table>

        </div>
    </div>
    ```

</div>

@code {

List<DebtView>? DebtList;

    string NameSearch = "";
    string PersonFilter = "all";
    string StatusFilter = "all";

    int YearFilter = 0;
    int MonthFilter = 0;
    DateTime? DayFilter = null;

    protected override async Task OnInitializedAsync()
    {
        DebtList = await FinanceService.GetDebts();
    }

    IEnumerable<DebtView> FilteredList =>
        (DebtList ?? new List<DebtView>())
        .Where(d =>
            (string.IsNullOrWhiteSpace(NameSearch) ||
             d.person_name.Contains(NameSearch, StringComparison.OrdinalIgnoreCase))

            && (PersonFilter == "all" ||
                (PersonFilter == "customer" && d.person_name.Contains("زبون")) ||
                (PersonFilter == "marketer" && d.person_name.Contains("مسوق")))

            && (StatusFilter == "all" ||
                (StatusFilter == "full" && d.paid_amount == 0) ||
                (StatusFilter == "partial" && d.paid_amount > 0))

            && (YearFilter == 0 || d.order_date.Year == YearFilter)

            && (MonthFilter == 0 || d.order_date.Month == MonthFilter)

            && (DayFilter == null || d.order_date.Date == DayFilter.Value.Date)
        );

    List<int> Years =>
        (DebtList ?? new())
        .Select(x => x.order_date.Year)
        .Distinct()
        .OrderByDescending(x => x)
        .ToList();

    string Fmt(decimal v) => $"{v:0.00} د.ل";


}
